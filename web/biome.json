{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignore": ["node_modules", "dist", "build", "src/api/generated", "coverage"]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },

  "organizeImports": {
    "enabled": true
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useExhaustiveDependencies": "error"
      },

      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["error", "warn", "info"] } },
        "noDoubleEquals": "error",
        "noImplicitAnyLet": "error"
      },

      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "noNonNullAssertion": "warn",
        "useSelfClosingElements": "error"
      },

      "a11y": {
        "recommended": true,
        "useButtonType": "error",
        "useValidAnchor": "error",
        "noAutofocus": "off"
      },

      "security": {
        "noDangerouslySetInnerHtml": "error"
      },

      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 15 }
        }
      },

      "performance": {
        "noDelete": "error"
      }
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  }
}
